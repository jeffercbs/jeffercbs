---
import Layout from "@/layouts/Layout.astro";
import type { MarkdownInstance } from "astro";

interface Frontmatter {
  title: string;
  description?: string;
}

const entry = Object.values(
  import.meta.glob<MarkdownInstance<Frontmatter>>("./About.mdx", {
    eager: true,
  })
);

const { Content } = entry[0];
---

<Layout title="sobre mi - about me">
  <main>
    <article
      class="md:max-w-4xl mx-auto px-2 w-full prose prose-invert prose-h1:text-center prose-h1:py-10 prose-h1:text-4xl prose-h1:md:text-7xl"
    >
      <Content />
    </article>
  </main>
</Layout>
