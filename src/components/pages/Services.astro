---
import { getI18n } from "@/i18n";
import Layout from "@/layouts/Layout.astro";
import CodeDeco from "../CodeDeco.astro";
import Tool from "../Tool.astro";
import Banner from "../partials/Banner.astro";
import Projects from "../partials/Projects.astro";

const { props, currentLocale } = Astro;
const i18n = getI18n({ currentLocale });
---

<Layout title={props.title}>
  <main class="hero">
    <section class="h-dvh flex flex-col items-start justify-center relative">
      <CodeDeco
        class="absolute -right-8 top-14"
        codelines={[
          "/**",
          " * HTML",
          " * CSS",
          " * JavaScript",
          " * Responsive Design",
          " * User Experience",
          "**/",
        ]}
      />
      <CodeDeco codelines={["hello()"]} />
      <CodeDeco codelines={["const message = ''"]} />
      <h2
        class="md:text-6xl text-balance text-4xl font-semibold md:max-w-3xl [&>strong]:text-yellow-300 [&>strong]:font-mono [&>span]:underline [&>span]:font-mono"
        set:html={i18n.SERVICES_INTRO}
      />
    </section>

    <div class="flex md:flex-row flex-col gap-x-8 gap-y-4 mb-12 relative">
      <CodeDeco
        codelines={[
          "/**",
          " * design",
          " * cms",
          " * testing",
          " * framework",
          " * workflows",
          " * libraries",
          "**/",
        ]}
        class="absolute -top-10 -right-20 md:-right-36"
      />
      <div class="md:w-[30%] w-full grid place-content-center">
        <p
          class="text-2xl text-pretty font-mono"
          set:text={i18n.SERVICES_TOOLS_DESC}
        />
      </div>
      <div
        class="flex-1 grid lg:grid-cols-5 md:grid-cols-3 grid-cols-2 gap-3 justify-center"
      >
        {
          [
            "react",
            "astrojs",
            "html",
            "planetscale",
            "supabase",
            "tailwind",
            "postgresql",
            "cloudinary",
            "shopify",
            "figma",
            "aws",
          ].map((tool) => <Tool {tool} />)
        }
      </div>
    </div>
    <Projects />
    <Banner />
  </main>
</Layout>
