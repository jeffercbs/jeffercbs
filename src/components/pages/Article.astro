---
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

export type Props = CollectionEntry<"blog">;
const {
  data: { title, cover, medium },
  slug,
} = Astro.props;
---

<Layout title={title}>
  <article class="pt-18">
    <div class="relative w-full h-[400px] mb-8 p-2 z-[1]">
      <Image
        transition:name={`image-a-${slug}`}
        src={cover}
        width={500}
        height={400}
        class="size-full rounded-xl"
        alt={title}
      />

      <div
        class="absolute grid place-content-center inset-0 size-full bg-neutral-900 bg-opacity-50 z-10"
      >
        <div class="text-white py-2 flex flex-col justify-center gap-y-3">
          <h1 transition:name={`title-${title}`} class="text-4xl font-bold">
            {title}
          </h1>
          <a
            href={medium}
            class="bg-white text-black px-4 py-1 rounded-full mt-4 text-center flex justify-center items-center gap-2"
            target="
            _blank"
            rel="noopener noreferrer"
          >
            <Icon name="medium" class="size-5" />
            <span> lectura en medium</span>
          </a>
        </div>
      </div>
    </div>
    <div class="prose prose-invert mx-auto">
      <slot />
    </div>
  </article>
</Layout>
