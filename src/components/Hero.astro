---
type Props = {
  title: string;
};
const { title } = Astro.props;
---

<div
  class="rounded-lg py-24 grid place-content-center mb-10 bg-center bg-cover"
  style="background: var(--gradient);"
>
  <h3
    class="text-3xl md:text-5xl font-bold md:max-w-2xl text-center"
    set:text={title}
  />
  <slot />
</div>
