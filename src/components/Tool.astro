---
import { Icon } from "astro-icon/components";

export type Props = {
  tool: string;
};

const { tool } = Astro.props;
---

<div
  class="h-fit bg-black/40 p-6 rounded-lg hover:shadow-blue-400/30 shadow-2xl transition-shadow ease-in-out"
>
  <div class="flex flex-col justify-center items-center size-full">
    <Icon name={tool} class="md:size-14 size-9 mb-3" />
    <small class="pt-4 uppercase md:text-sm text-[8px] font-semibold">
      {tool}
    </small>
  </div>
</div>
