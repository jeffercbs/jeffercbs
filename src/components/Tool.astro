---
import { Icon } from "astro-icon/components";

export type Props = {
  tool: string;
};

const { tool } = Astro.props;
---

<div
  class="h-fit bg-black/40 p-6 rounded-md hover:shadow-green-400/40 shadow-2xl transition-shadow ease-in-out"
>
  <div class="flex flex-col justify-center items-center size-full">
    <Icon name={tool} class="size-14 mb-3" />
    <span class="capitalize pt-4 text-sm font-mono">{tool}</span>
  </div>
</div>
