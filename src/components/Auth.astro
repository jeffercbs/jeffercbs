---
import { Icon } from "astro-icon/components";

type Props = {
  name: string;
  username: string;
  image?: string;
  medium?: string;
  readingTime?: string;
};

const { name, username, image, medium, readingTime } = Astro.props;
---

<div class="flex items-center gap-4">
  <div
    class="size-10 grid place-content-center bg-gradient-to-br from-primary to-secondary rounded-full"
  >
    <span class="font-medium"> JB </span>
  </div>
  <div class="flex flex-col justify-center items-start font-medium text-white">
    <strong set:text={name} />
    <div class="flex items-center gap-x-2">
      <small class="text-sm text-gray-400" set:text={username} />
      <span> * </span>
      <small set:text={readingTime} />
      {
        medium && (
          <span>*</span>
          <a href={medium} target="_blank" class="flex items-center gap-x-2 hover:underline">
            <Icon name="medium" class="size-4" />
            <small>leer en medium</small>
          </a>
        )
      }
    </div>
  </div>
</div>
