---
import { getI18n } from "@/i18n";
import Link from "./Link.astro";

export type Props = {
  title?: string;
  description?: string;
  cover?: string;
  link?: string;
  repo?: string;
  slug: string;
  class?: string;
};

const { currentLocale } = Astro;
const i18n = getI18n({ currentLocale });

const { title, description, link, repo, cover, slug } = Astro.props;
---

<article
  class="card relative group flex flex-col gap-x-6 p-8 h-fit bg-black/40 border border-white/10 text-white/50 hover:bg-white/5 rounded-2xl transition-colors ease-in-out"
>
  <div class="flex flex-col pb-5 relative z-[1]">
    <div class="block gap-y-4">
      <h3 class="text-2xl font-bold text-green-100 mb-2">
        {title}
      </h3>
      <p class="mb-4 text-pretty opacity-90" set:text={description} />
    </div>
    <div class="flex gap-x-4 font-semibold">
      <Link href={link || "#"} variant="link" external>visualizar</Link>
      <Link href={`/projects/${slug}`} variant="link">{i18n.PROJECT_CASE}</Link>
      {repo && <Link href={repo} variant="link" icon="github" external />}
    </div>
  </div>
  <div class="rounded-2xl overflow-hidden flex-1 md:w-fit w-full h-full">
    <img
      src={`/_thumbnails/${cover}`}
      width="700"
      height="500"
      loading="lazy"
      alt={title}
      class="aspect-video size-full object-cover group-hover:scale-110 ease-in-out transition duration-300"
    />
  </div>
</article>

<style>
  .card {
    animation: linear both reveal;
    animation-range: 5% 15%;
    animation-timeline: view();
  }

  @keyframes reveal {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    50% {
      opacity: 0.1;
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
