---
import CardTestimony from "../CardTestimony.astro";
---

<section id="testimonies" class="relative overflow-hidden">
  <div class="text-center h-36 md:max-w-2xl mx-auto">
    <h2
      class="text-center bg-clip-text text-transparent bg-gradient-to-l to-white/70 from-green-200 md:text-5xl text-4xl text-pretty font-semibold"
    >
      Más que palabras, el trabajo habla por nosotros
    </h2>
  </div>
  <div
    data-testimonials=""
    class="relative data-[testimonials-closed]:mb-0 duration-1000 transition-all testimonials-mask"
  >
    <ul class="mt-10 columns-1 gap-5 sm:columns-2 sm:gap-7 md:columns-3 pb-16">
      {
        [
          {
            name: "Argermiro Remodelaciones",
            position: "emprendedor y cliente",
            company: "argermiroremodelaciones",
            image: "/logo.webp",
            text: "El sitio web desarrollado para mi empresa de remodelaciones ha sido clave para atraer más clientes. Desde su lanzamiento, el alcance de nuestros servicios crecido significativamente. El proceso fue profesional y se ajustó perfectamente a nuestras necesidades.",
          },
          {
            name: "Camilo Davila",
            position: "Ingeniero de sistemas",
            company: "MINTIC",
            image: "/banner.webp",
            text: "Es un programador altamente capacitado, con gran dominio de diversas tecnologías y excelente habilidad para resolver problemas. Siempre profesional y eficiente. Totalmente recomendable.",
          },
          {
            name: "Angie Rey",
            position: "CEO de ar belleza",
            company: "Company",
            image: "/ar.webp",
            text: "Jeferson es una persona comprometida, dedicada e inteligente. Disfruta el trabajo en equipo, siendo esto soft skills muy atrayente para las empresas a la vanguardia, tiene toda la disposición para ayudar a los demás y se ve que disfruta cuando lo hace. ",
          },
        ].map((testimonial) => (
          <li class="p-5 break-inside-avoid mb-7 bg-white/5 border border-white/10 text-white/50 hover:bg-white/10 rounded-2xl">
            <CardTestimony {...testimonial} />
          </li>
        ))
      }
    </ul>
  </div>
  <!-- <div
    class="inset-x-0 bottom-0 flex justify-center bg-gradient-to-t pt-32 pb-8 pointer-events-none backdrop-blur-sm absolute"
  >
   <button type="button" class="relative bg-slate-900 hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2 text-sm text-white font-semibold h-12 px-6 rounded-lg flex items-center dark:bg-slate-700 dark:hover:bg-slate-600 pointer-events-auto">
      Show more...
    </button> 
  </div> -->
</section>
