---
import { getI18n } from "@/i18n";
import Image from "astro/components/Image.astro";

const { currentLocale } = Astro;
const i18n = getI18n({ currentLocale });
---

<section id="about" class="h-fit py-14">
  <div class="hero flex md:flex-row gap-8 flex-col">
    <div class="md:w-2/5 w-full flex items-center justify-center px-6">
      <div class="aspect-auto p-4">
        <Image
          src="/yo.jpg"
          width="300"
          height="400"
          class="size-full object-contain rounded-2xl min-h-60 shadow-2xl shadow-white/40 rotate-3"
          alt="i am jeffercbs"
        />
      </div>
    </div>
    <div class="flex-1 flex md:flex-row flex-col gap-x-8 gap-y-4 my-4">
      <div
        class="flex flex-col flex-1 gap-y-4 md:order-1 order-2 [&>p]:text-[17px] [&>p]:text-pretty [&>p>em]:italic [&>p>strong]:font-mono [&>p>strong]:px-1 [&>p>strong]:text-yellow-100"
        set:html={i18n.ABOUT_DESC}
      />
    </div>
  </div>
</section>
