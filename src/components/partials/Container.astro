---
export type Props = {
  title: string;
  id: string;
  tag?: string;
  description?: string;
};

const { title, id, description, tag } = Astro.props;
---

<section class="relative overflow-hidden my-10" id={id}>
  <div class="container py-8 text-left md:max-w-2xl w-full">
    {
      tag && (
        <span class="text-base bg-clip-text text-transparent bg-gradient-to-l to-green-400 from-lime-400">
          {tag}
        </span>
      )
    }
    <h2 class="text-4xl font-bold text-balance">{title}</h2>
    {
      description && (
        <p class=" text-gray-400 mt-1 text-lg text-pretty">{description}</p>
      )
    }
  </div>
  <slot />
</section>
