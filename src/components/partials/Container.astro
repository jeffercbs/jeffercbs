---
export type Props = {
  title?: string;
  id: string;
  tag?: string;
  description?: string;
  class?: string;
};

const { title, id, description, tag, class: classes } = Astro.props;
---

<section class:list={["relative py-14", classes]} id={id}>
  <div class="hero">
    <div class="container py-8 text-left md:max-w-2xl w-full mb-4">
      {
        tag && (
          <span
            style="text-shadow: var( --text-shadow);"
            class="text-lg bg-clip-text text-transparent bg-gradient-to-r from-white to-blue-400 uppercase font-bold"
          >
            {tag}
          </span>
        )
      }
      {title && <h2 class="text-4xl font-bold text-balance">{title}</h2>}
      {
        description && (
          <p class="mt-4 opacity-70 text-lg text-pretty">{description}</p>
        )
      }
    </div>

    <slot />
  </div>
</section>
