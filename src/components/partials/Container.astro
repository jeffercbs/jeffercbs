---
export type Props = {
  title?: string;
  id: string;
  tag?: string;
  description?: string;
  class?: string;
};

const { title, id, description, tag, class: classes } = Astro.props;
---

<section class:list={["relative py-16 h-fit", classes]} id={id}>
  <div class="container text-left md:max-w-2xl w-full mb-4 md:px-0 px-2">
    {
      tag && (
        <span class="bg-green-400 text-black capitalize px-4 py-1 rounded-full inline-block mb-4 font-medium">
          {tag}
        </span>
      )
    }
    {title && <h2 class="text-4xl font-bold text-balance">{title}</h2>}
    {
      description && (
        <p class="mt-4 opacity-70 text-lg text-pretty">{description}</p>
      )
    }
  </div>
  <slot />
</section>
