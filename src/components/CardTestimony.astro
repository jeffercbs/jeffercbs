---
type Props = {
  name: string;
  position: string;
  company: string;
  image: string;
  text: string;
};

const { name, position, image, text } = Astro.props;
---

<article
  class="p-5 bg-white/5 hover:bg-white/10 transition-colors ease-in-out border border-white/10 backdrop-blur-md rounded-2xl"
>
  <header class="flex items-center gap-2.5">
    <img
      src={image}
      alt="Avatar de Mateo Álvarez"
      loading="lazy"
      width="50"
      height="50"
      class="size-12 aspect-square rounded-full object-cover"
    />
    <div class="flex flex-col">
      <h3 class="text-white font-semibold" set:text={name} />
      <small class="text-white/60" set:text={position} />
    </div>
  </header>
  <p class="text-white/70 mt-2.5" set:text={text} />
</article>
